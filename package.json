{
  "name": "cohesive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "postinstall": "patch-package",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.eval.json",
    "typecheck:eval": "tsc -p tsconfig.eval.json",
    "eval": "EVAL_SKIP_LIVE=1 vitest run --config evals/vitest.config.ts",
    "eval:all": "vitest run --config evals/vitest.config.ts",
    "eval:unit": "EVAL_SKIP_LIVE=1 vitest run --config evals/vitest.config.ts evals/cases/loop-unit.eval.ts",
    "eval:live": "vitest run --config evals/vitest.config.ts evals/cases/explore-build.eval.ts evals/cases/long-context.eval.ts",
    "eval:export": "node --import tsx evals/scripts/export-trace.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.4",
    "@fontsource-variable/inter": "^5.2.8",
    "@streamdown/code": "^1.1.1",
    "@tauri-apps/api": "^2.4.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "codemirror": "^6.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "streamdown": "^2.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2.4.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^11.9.1",
    "glob": "^11.0.1",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.9"
  }
}
